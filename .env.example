# ============================================
# RTS MONITORING SYSTEM - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your values
# For Vercel deployment, add these in Vercel Dashboard → Settings → Environment Variables

# ============================================
# SUPABASE CONFIGURATION (PRIMARY DATA SOURCE)
# ============================================
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# ============================================
# NEXTAUTH CONFIGURATION
# ============================================
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-32-character-secret-here
# For local: http://localhost:3000
# For Vercel: https://your-app-name.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ============================================
# GOOGLE SHEETS (LEGACY - Optional for migration)
# ============================================
# Only needed if you're still migrating data from Google Sheets
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_SHEET_ID=your-google-sheet-id-here

# ============================================
# VERCEL DEPLOYMENT INSTRUCTIONS
# ============================================
# 1. Go to Vercel Dashboard → Your Project → Settings → Environment Variables
# 2. Add each variable above (except GOOGLE_SHEETS if not needed)
# 3. Select environments: Production, Preview, Development
# 4. Click "Save"
# 5. Redeploy your application
#
# Quick CLI setup:
#   vercel env add NEXT_PUBLIC_SUPABASE_URL
#   vercel env add NEXT_PUBLIC_SUPABASE_ANON_KEY
#   vercel env add NEXTAUTH_SECRET
#   vercel env add NEXTAUTH_URL
